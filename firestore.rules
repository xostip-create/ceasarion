/**
 * Ceasarion: Ad Arbitrage Middleman Security Rules
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * Global Helper Functions
     */
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return isSignedIn() && resource != null && request.auth.uid == ownerId;
    }

    /**
     * @description Rules for the root User document.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Rules for private Ad Configuration settings.
       * @path /users/{userId}/adConfig/{configId}
       */
      match /adConfig/{configId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      /**
       * @description Rules for Ad Impression Events (Analytics).
       */
      match /adImpressionEvents/{impressionId} {
        allow create: if true;
        allow get, list: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Ad Click Events (Analytics).
       */
      match /adClickEvents/{clickId} {
        allow create: if true;
        allow get, list: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for publicly accessible Landing Page content.
     */
    match /public_landing_pages/{landingPageSlug} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }
  }
}
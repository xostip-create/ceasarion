
{
  "entities": {
    "AdConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdConfig",
      "type": "object",
      "description": "Global ad configuration settings for the arbitrage engine.",
      "properties": {
        "smartLink": {
          "type": "string",
          "description": "The primary Adsterra Smart Link URL."
        },
        "popUnderScript": {
          "type": "string",
          "description": "The HTML/JS script for the Pop-under ad format."
        },
        "nativeBannerScript": {
          "type": "string",
          "description": "The HTML/JS script for the Native Banner ad format."
        },
        "aggressiveBrowsers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of browser names that trigger the aggressive fallback logic (e.g., Brave, Firefox)."
        }
      }
    },
    "LandingPage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LandingPage",
      "type": "object",
      "description": "Represents a single landing page designed to receive traffic and display dynamic advertisements.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "adConfig": { "$ref": "#/backend/entities/AdConfig" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "AdImpressionEvent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdImpressionEvent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landingPageId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "browserType": { "type": "string" },
        "adblockerStatus": { "type": "string" }
      }
    },
    "AdClickEvent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdClickEvent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landingPageId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "browserType": { "type": "string" },
        "adblockerStatus": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/adConfig/settings",
        "definition": {
          "entityName": "AdConfig",
          "schema": { "$ref": "#/backend/entities/AdConfig" },
          "description": "Private ad configuration settings managed by the owner."
        }
      },
      {
        "path": "/public_landing_pages/{id}",
        "definition": {
          "entityName": "LandingPage",
          "schema": { "$ref": "#/backend/entities/LandingPage" },
          "description": "Publicly accessible landing page data including ad configurations."
        }
      }
    ]
  }
}
